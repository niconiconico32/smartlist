{
  "expo": {
    "name": "Brainy",
    "slug": "brainy",
    "version": "1.0.13",
    "orientation": "default",
    "icon": "./assets/images/appstorelogo.png",
    "scheme": "brainy",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#280D8C"
    },
    "ios": {
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Allow $(PRODUCT_NAME) to use speech recognition.",
        "NSMicrophoneUsageDescription": "Allow $(PRODUCT_NAME) to use the microphone.",
        "NSUserTrackingUsageDescription": "This identifier will be used to measure the effectiveness of advertising and improve your experience in the app."
      },
      "bundleIdentifier": "com.brainyahdh.app",
      "buildNumber": "11"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/appstorelogo.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.brainyahdh.app",
      "versionCode": 16,
      "permissions": [
        "POST_NOTIFICATIONS",
        "VIBRATE",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "blockedPermissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "ios": {
            "newArchEnabled": true
          },
          "android": {
            "newArchEnabled": true,
            "enableJetpackCompose": true,
            "kotlinVersion": "2.0.21"
          }
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Necesitamos acceso a tu micrófono para que puedas dictar nuevas tareas."
        }
      ],
      "expo-audio",
      "expo-speech-recognition",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/appstorelogo.png",
          "color": "#CBA6F7",
          "defaultChannel": "routines"
        }
      ],
      "expo-apple-authentication",
      "./plugins/withRemoveBootReceiver",
      "./plugins/withUnrestrictMLKitOrientation",
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "RoutinesWidget",
              "label": "Rutinas Brainy",
              "minWidth": "320dp",
              "minHeight": "56dp",
              "targetCellWidth": 4,
              "targetCellHeight": 1,
              "maxResizeWidth": "320dp",
              "maxResizeHeight": "56dp",
              "description": "Muestra tus rutinas del día.",
              "previewImage": "./assets/images/logomain.png",
              "resizeMode": "none"
            }
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0025faea-a07f-4447-9b45-fd5edb5469a9"
      }
    }
  }
}